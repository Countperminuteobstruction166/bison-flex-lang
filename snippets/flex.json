{
  "Flex Scanner Skeleton": {
    "prefix": "flex-skeleton",
    "description": "Complete Flex scanner file skeleton",
    "body": [
      "/* -*- C++ -*- */",
      "%option noyywrap",
      "%option nounput",
      "%option noinput",
      "",
      "%{",
      "  #include <string>",
      "  #include \"${1:parser.hh}\"",
      "  $2",
      "%}",
      "",
      "/* Abbreviations */",
      "int       [0-9]+",
      "spaces    [ \\t]+",
      "id        [a-zA-Z_][a-zA-Z0-9_]*",
      "",
      "%%",
      "/* Rules */",
      "",
      "{spaces}  { /* skip whitespace */ }",
      "\\n       { /* handle newline */ }",
      "",
      "{int}     {",
      "            return ${3:TOKEN}(INT, atoi(yytext));",
      "          }",
      "",
      "{id}      {",
      "            return ${3}(ID, yytext);",
      "          }",
      "",
      ".         {",
      "            /* error: unexpected character */",
      "          }",
      "",
      "%%"
    ]
  },
  "RE-flex Scanner Skeleton": {
    "prefix": "reflex-skeleton",
    "description": "Complete RE-flex scanner file skeleton",
    "body": [
      "/* -*- C++ -*- */",
      "%option noyywrap",
      "%option bison-complete",
      "%option bison-cc-parser=${1:parser}",
      "%option bison_cc_namespace=${2:parse}",
      "%option bison-locations",
      "%option lex=lex",
      "%option namespace=${2}",
      "%option lexer=${3:Lexer}",
      "",
      "%top{",
      "  #include <string>",
      "  #include \"${4:parser.hh}\"",
      "  $5",
      "}",
      "",
      "/* Abbreviations */",
      "int       [0-9]+",
      "spaces    [ \\t]+",
      "id        [a-zA-Z_][a-zA-Z0-9_]*",
      "",
      "%%",
      "/* Rules */",
      "",
      "{spaces}  { /* skip whitespace */ }",
      "\\n       { /* handle newline */ }",
      "",
      "$6",
      "",
      ".         {",
      "            /* error: unexpected character */",
      "          }",
      "",
      "%%"
    ]
  },
  "Rule with Action": {
    "prefix": "rule",
    "description": "Flex rule with action block",
    "body": [
      "${1:pattern}  {",
      "            ${2:action}",
      "          }"
    ]
  },
  "Rule with Start Condition": {
    "prefix": "rule-sc",
    "description": "Flex rule with start condition",
    "body": [
      "<${1:CONDITION}>${2:pattern}  {",
      "            ${3:action}",
      "          }"
    ]
  },
  "Start Condition Exclusive": {
    "prefix": "%x",
    "description": "Exclusive start condition declaration",
    "body": [
      "%x ${1:SC_NAME}"
    ]
  },
  "Start Condition Inclusive": {
    "prefix": "%s",
    "description": "Inclusive start condition declaration",
    "body": [
      "%s ${1:SC_NAME}"
    ]
  },
  "Option Directive": {
    "prefix": "%option",
    "description": "%option directive",
    "body": [
      "%option ${1|noyywrap,nounput,noinput,nodefault,debug,bison-complete,bison-locations,reentrant,yylineno,stack,8bit,prefix|}"
    ]
  },
  "Top Block": {
    "prefix": "%top",
    "description": "%top code block",
    "body": [
      "%top{",
      "  $1",
      "}"
    ]
  },
  "Class Block": {
    "prefix": "%class",
    "description": "%class member block (RE-flex)",
    "body": [
      "%class{",
      "  $1",
      "}"
    ]
  },
  "Prologue Block": {
    "prefix": "%{",
    "description": "Prologue code block",
    "body": [
      "%{",
      "  $1",
      "%}"
    ]
  },
  "Comment Block Handler": {
    "prefix": "comment-handler",
    "description": "Nested comment handler with start condition",
    "body": [
      "/* Comments */",
      "\"/*\"              {",
      "                    ${1:comment_depth} = 1;",
      "                    start(${2:SC_COMMENT});",
      "                  }",
      "<$2>\"/*\"  { $1++; }",
      "<$2>\"*/\"  {",
      "                    $1--;",
      "                    if ($1 == 0)",
      "                      start(INITIAL);",
      "                  }",
      "<$2>\"\\n\"  { /* track newlines */ }",
      "<$2><<EOF>> {",
      "                    /* error: unterminated comment */",
      "                    start(INITIAL);",
      "                  }",
      "<$2>.     { /* ignore */ }"
    ]
  },
  "String Handler": {
    "prefix": "string-handler",
    "description": "String literal handler with start condition",
    "body": [
      "/* Strings */",
      "\"\\\"\"              {",
      "                    ${1:string_content}.clear();",
      "                    start(${2:SC_STRING});",
      "                  }",
      "<$2>\"\\\"\"   {",
      "                    start(INITIAL);",
      "                    return TOKEN_VAL(STRING, $1);",
      "                  }",
      "<$2>\\\\\\\\n  { $1 += '\\n'; }",
      "<$2>\\\\\\\\t  { $1 += '\\t'; }",
      "<$2>\\\\\\\\\\\"  { $1 += '\\\"'; }",
      "<$2>\\\\\\\\\\\\\\\\  { $1 += '\\\\'; }",
      "<$2><<EOF>> {",
      "                    /* error: unterminated string */",
      "                    start(INITIAL);",
      "                  }",
      "<$2>.      { $1 += text(); }"
    ]
  },
  "EOF Handler": {
    "prefix": "eof-handler",
    "description": "EOF handler with start condition",
    "body": [
      "<${1:CONDITION}><<EOF>> {",
      "                    ${2:/* error handling */}",
      "                    start(INITIAL);",
      "                  }"
    ]
  },

  "Number Handler": {
    "prefix": "number-handler",
    "description": "Complete numeric literal handler: integers, floats, and scientific notation",
    "body": [
      "/* --- Numeric literals --- */",
      "[0-9]+  {",
      "          ${1:yylval.ival} = atoi(yytext);",
      "          return ${2:INTEGER};",
      "        }",
      "",
      "[0-9]*\\.[0-9]+([eE][+-]?[0-9]+)?  {",
      "          ${3:yylval.dval} = atof(yytext);",
      "          return ${4:FLOAT};",
      "        }",
      "",
      "[0-9]+[eE][+-]?[0-9]+  {",
      "          ${3} = atof(yytext);",
      "          return ${4};",
      "        }"
    ]
  },

  "Identifier Handler": {
    "prefix": "identifier-handler",
    "description": "Identifier rule with optional keyword table lookup",
    "body": [
      "/* --- Identifiers --- */",
      "[a-zA-Z_][a-zA-Z0-9_]*  {",
      "          ${1:yylval.sval} = strdup(yytext);",
      "          int kw = ${2:keyword_lookup}(yytext);",
      "          return kw ? kw : ${3:IDENTIFIER};",
      "        }"
    ]
  },

  "Multiline Comment Handler": {
    "prefix": "multiline-comment",
    "description": "Nested /* */ comment handler with depth counter and BEGIN() (standard Flex)",
    "body": [
      "/* --- Nested C-style comments (standard Flex) --- */",
      "%x ${1:SC_COMMENT}",
      "",
      "/* Declare in your C prologue: int ${2:comment_depth}; */",
      "",
      "\"/*\"  {",
      "          ${2} = 1;",
      "          BEGIN(${1});",
      "        }",
      "<${1}>\"/*\"  { ${2}++; }",
      "<${1}>\"*/\"  {",
      "          if (--${2} == 0)",
      "            BEGIN(INITIAL);",
      "        }",
      "<${1}>\\n    { /* count lines: yylineno++; */ }",
      "<${1}><<EOF>>  {",
      "          yyerror(\"unterminated comment\");",
      "          BEGIN(INITIAL);",
      "        }",
      "<${1}>.   { /* discard comment content */ }"
    ]
  }
}
